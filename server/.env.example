# ===========================================
# HVAC Monitor - Backend Configuration
# ===========================================

# --------------------------------------------
# AI API Keys
# --------------------------------------------

# Google Gemini API
# Get your API key from: https://ai.google.dev/
# Used as primary AI explanation provider
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (FREE fallback)
# Get your API key from: https://console.groq.com/keys
# Unlimited free tier - used when Gemini quota is exceeded
GROQ_API_KEY=your_groq_api_key_here

# --------------------------------------------
# Sensor Data Configuration
# --------------------------------------------

# Sensor Data Mode
# Options: 'csv' (static historical replay) or 'realtime' (live simulation)
# csv mode: Replays data from assets/hvac_sensor_data.csv
# realtime mode: Generates live sensor data with dynamic anomaly injection
SENSOR_MODE=realtime

# --------------------------------------------
# LangSmith Observability (Optional)
# --------------------------------------------

# LangSmith API Key
# Get from: https://smith.langchain.com/settings
# Provides LLM call tracing, performance metrics, and error tracking
# Leave empty to disable LangSmith tracking
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Enable LangSmith tracing
LANGCHAIN_TRACING_V2=true

# LangSmith project name
LANGCHAIN_PROJECT=hvac-monitor

# --------------------------------------------
# Server Configuration (Optional)
# --------------------------------------------

# Server port (default: 3000)
# PORT=3000

# Node environment (development, production)
# NODE_ENV=development
